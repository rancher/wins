{
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main",
    "release/v2.11",
    "release/v2.12",
    "release/v2.13",
    "release/v2.14",
    "release/v2.15"
  ],
  "prHourlyLimit": 2,
  "reviewers": [
    "HarrisonWAffel"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^build\\.json$/"
      ],
      "matchStrings": [
        "\"repo\":\\s*\"(?<depName>[^\"]+)\",\\s*\"tag\":\\s*\"(?<currentValue>[^\"]+)\",\\s*\"sha\":\\s*\"(?<currentDigest>sha256:[a-f0-9]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
